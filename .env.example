# Stripe secret key (required only for live API mode; not needed for CSV-only use)
# Restricted keys (rk_live_...): https://dashboard.stripe.com/apikeys — enable "Read charges"
#   (Stripe internal name: rak_charge_read). Without it, Charge.list fails.
STRIPE_API_KEY=sk_live_...

# Optional: restricted key alias (either variable name is accepted)
# STRIPE_API_KEY_RESTRICTED=rk_live_...

# IntegraLOOP / BILOOP Accounting API
# Example: https://<host> (no trailing slash)
ACCOUNTING_BASE_URL=https://api.example.com
# Header name per OpenAPI: SUBSCRIPTION_KEY
ACCOUNTING_SUBSCRIPTION_KEY=your_subscription_key_here
# Optional (if you want the app to auto-fetch a 2h token via GET /api-global/v1/token)
ACCOUNTING_USER=your_user_here
ACCOUNTING_PASSWORD=your_password_here
# Optional (if you already have a token; sent as header "token")
ACCOUNTING_TOKEN=your_token_here

# vertex.ai / Google API key
GOOGLE_API_KEY=your-vertex-ai-studio-api-key